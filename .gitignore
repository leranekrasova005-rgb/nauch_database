```gitignore
# Compiled and build artifacts
*.js
*.jsx
*.ts
*.tsx
*.css
*.scss
*.sass
*.less
*.map

# Dependencies
node_modules/

# Build outputs
dist/
build/
out/
bundle/

# Logs and temp files
*.log
*.tmp
*.swp
*.swo

# Environment
.env
.env.local
.env.*

# Editors
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# OS generated files
.DS_Store
Thumbs.db

# Coverage reports
coverage/
htmlcov/
.coverage

# Python specific
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so
.pytest_cache/
.mypy_cache/

# Node specific
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Temporary files
*.tmp
*.temp
*~
.DS_Store
Thumbs.db
```